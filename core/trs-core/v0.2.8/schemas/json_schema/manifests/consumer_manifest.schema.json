{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Consumer Manifest",
  "type": "object",
  "required": [
    "consumer",
    "consumer_version",
    "contract_version",
    "used_tag_ids",
    "generated_at_utc"
  ],
  "properties": {
    "consumer": {
      "type": "string"
    },
    "consumer_version": {
      "type": "string"
    },
    "contract_version": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+\\.\\d+$"
    },
    "used_tag_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "generated_at_utc": {
      "type": "string"
    }
  },
  "additionalProperties": true
}